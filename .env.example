# ── Base de datos ─────────────────────────────────────────
# Nombre de tu BBDD existente en MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=Repuestos
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# ── JWT ───────────────────────────────────────────────────
# Clave secreta larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_por_una_clave_larga_y_segura_aqui
JWT_EXPIRES_IN=8h

# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production
